# Port configuration (Render will assign this automatically, default is 5000)
PORT=5000

# Connection URI for MongoDB Atlas or database
MONGO_URI=mongodb+srv://<username>:<password>@your-cluster.tbdnwye.mongodb.net/?appName=taskflow-cluster

# URL pointing to the deployed Vercel frontend (for CORS validation in production)
FRONTEND_URL=https://your-frontend-app.vercel.app

# Environment mode
NODE_ENV=production
